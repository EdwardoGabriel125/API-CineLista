doctype html
html
  head
    title CineLista - Erro #{status}
    link(rel="stylesheet", href="/css/style.css")
  body
    div(style="text-align: center; margin-top: 50px;")
      h1 ⚠️ #{titulo || "Ocorreu um erro"}
      h2 Status: #{status}
      p(style="color: gray;")= mensagem
      
      br
      if status == 404
        p Parece que essa página não existe.
      else if status == 403
        p Você não tem permissão para realizar esta ação.
      
      hr
      a(href="/api/cinema/all") 🏠 Voltar para a página inicial
